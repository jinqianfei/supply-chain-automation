{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "统一订单结构化JSON",
  "type": "object",
  "properties": {
    "order_date": {"type": "string", "description": "订单日期"},
    "store_name": {"type": "string", "description": "门店名称"},
    "store_phone": {"type": "string", "description": "门店联系电话"},
    "store_address": {"type": "string", "description": "门店收货地址"},
    "warehouse": {"type": "string", "description": "仓库名称"},
    "raw_order_no": {"type": "string", "description": "原始订单号"},
    "extra_notes": {"type": "string", "description": "额外备注"},
    "shipper_name": {"type": "string", "description": "货主公司全称"},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "product_name": {"type": "string", "description": "商品名称"},
          "product_spec": {"type": "string", "description": "商品规格"},
          "unit": {"type": "string", "description": "单位"},
          "quantity": {"type": "integer", "description": "数量"},
          "remark": {"type": "string", "description": "备注"}
        },
        "required": ["product_name", "quantity"]
      }
    }
  },
  "required": ["store_name", "items"]
}
