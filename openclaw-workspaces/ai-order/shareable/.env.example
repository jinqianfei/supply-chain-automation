# =============================================================
# skill_order_to_huading_template v5.11.1 配置示例
# 复制为 .env 并填入你的真实值（**不要**提交 .env 到 git）
# =============================================================

# ---------- 数据库（必填）----------
DB_HOST=your-db-host.amazonaws.com
DB_PORT=5432
DB_NAME=neo
DB_USER=your_user
DB_PASSWORD=your_password
DB_SSLMODE=prefer

# ---------- LLM 提供商（可选，默认用 OpenClaw 内嵌模型）----------
# 留空 = 用 OpenClaw 平台内嵌模型（无需 key）
OPENAI_API_KEY=
MINIMAX_API_KEY=

# ---------- Redis（可选，用于缓存）----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
