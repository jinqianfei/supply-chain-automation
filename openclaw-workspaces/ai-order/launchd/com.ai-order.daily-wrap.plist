<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ai-order.daily-wrap</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>/bin/bash "$AI_ORDER_WORKSPACE/ops/daily_wrap.sh"</string>
    </array>

    <!-- 每天 10:00 触发（金姐指定：总结昨天数据） -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>10</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- 标准输出/错误 → 日志文件 -->
    <key>StandardOutPath</key>
    <string>/tmp/ai-order.daily-wrap.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/ai-order.daily-wrap.err.log</string>

    <!-- 环境变量 -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>AI_ORDER_WORKSPACE</key>
        <string>__WORKSPACE__</string>
    </dict>

    <!-- 进程退出码 0 = OK，非 0 = 失败（不重试） -->
    <key>ExitTimeOut</key>
    <integer>300</integer>
</dict>
</plist>
